.r-o-o-t {
  min-height: 100vh;
  background: linear-gradient(160deg,#0c0008 0%,#1e0510 45%,#08000e 100%);
  color: #fff;
  font-family: "Impact","Arial Narrow",Arial,sans-serif;
}

.t-o-p-b-a-r {
  background: linear-gradient(90deg,#6e0000 0%,#cc0000 50%,#6e0000 100%);
  padding: 5px 0;
  text-align: center;
  font-size: 11px;
  letter-spacing: 4;
  color: #FFD700;
  border-bottom: 2px solid #FFD700;
  font-family: "Impact",Arial;
}

.w {
  custom: true;
}

.i-n-p {
  padding: 9px 12px;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.13);
  border-radius: 5px;
  font-size: 13px;
  font-family: Arial;
  width: 100%;
}
